            VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 0)
            task.wait(0.03)
            VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 0)
        end)
        if okMouse then
            return true
        end
    end

    return false
end

local function queueNpcPromptConfirm(kind, npcName)
    Runtime.pendingNpcPrompt = {
        kind = kind,
        npcName = npcName,
        expiresAt = os.clock() + 6,
    }
end

local function triggerAnyPrompt(model, promptKind)
    if not model then
        return false
    end

    queueNpcPromptConfirm(promptKind, model.Name)

    for _, descendant in ipairs(model:GetDescendants()) do
        if descendant:IsA("ProximityPrompt") then
            if fireproximityprompt then
                local ok = pcall(function()
                    fireproximityprompt(descendant)
                end)
                if ok then
                    return true
                end
            end

            local ok = pcall(function()
                descendant:InputHoldBegin()
                task.wait(0.15)
                descendant:InputHoldEnd()
            end)
            if ok then
                return true
            end
        end
    end

    return false
end

local function inLair()
    local character = LocalPlayer.Character
    local flag = character and character:FindFirstChild("InLair")
    return flag and flag.Value == true
end

local function buildCentroidForEnemies(enemyNames)
    local living = getLivingFolder()
    if not living or not enemyNames or #enemyNames == 0 then
        return nil
    end

    local sum = Vector3.zero
    local count = 0

    for _, npc in ipairs(living:GetChildren()) do
        if isHostileNpc(npc) and nameMatches(npc.Name, enemyNames) then
            local root = getRoot(npc)
            if root then
                sum = sum + root.Position
                count = count + 1
            end
        end
    end

    if count == 0 then
        return nil
    end

    return sum / count
end

local function getQuestNpcCandidates(enemyNames)
    local folder = getNpcFolder()
    local playerRoot = getPlayerRoot()
    if not folder or not playerRoot then
        return {}
    end

    local centroid = buildCentroidForEnemies(enemyNames)
    local scored = {}

    for _, npc in ipairs(folder:GetChildren()) do
        local npcRoot = getRoot(npc)
        if npcRoot then
            local score = centroid and (npcRoot.Position - centroid).Magnitude or (npcRoot.Position - playerRoot.Position).Magnitude

            if isTaggedName(npc.Name, NON_QUEST_NPC_HINTS) then
                score = score + 4000
            end

            table.insert(scored, {
                model = npc,
                score = score,
            })
        end
    end

    table.sort(scored, function(a, b)
        return a.score < b.score
    end)

    local out = {}
    for _, entry in ipairs(scored) do
        uniquePush(out, entry.model.Name)
    end

    return out
end

local function getAutoDungeonNpcCandidates()
    local out = {}
    if Runtime.dungeonLoop.successfulNpc then
        uniquePush(out, Runtime.dungeonLoop.successfulNpc)
    end

    local route = getRouteForLevel(currentLevel())
    for _, hint in ipairs(route.dungeonNpcHints or {}) do
        uniquePush(out, hint)
    end

    local folder = getNpcFolder()
    local playerRoot = getPlayerRoot()
    if folder and playerRoot then
        local scored = {}
        for _, npc in ipairs(folder:GetChildren()) do
            local npcRoot = getRoot(npc)
            if npcRoot then
                local loweredName = lower(npc.Name)
                local score = (npcRoot.Position - playerRoot.Position).Magnitude

                if isTaggedName(loweredName, KNOWN_DUNGEON_HINTS) then
                    score = score - 2000
                else
                    score = score + 2000
                end

                if isTaggedName(loweredName, NON_QUEST_NPC_HINTS) and not isTaggedName(loweredName, KNOWN_DUNGEON_HINTS) then
                    score = score + 3000
                end

                table.insert(scored, {
                    name = npc.Name,
                    score = score,
                })
            end
        end

        table.sort(scored, function(a, b)
            return a.score < b.score
        end)

        for _, entry in ipairs(scored) do
            uniquePush(out, entry.name)
        end
    end

    return out
end

local function resolveNpcByName(name)
    local folder = getNpcFolder()
    if not folder then
        return nil
    end

    for _, npc in ipairs(folder:GetChildren()) do
        if lower(npc.Name) == lower(name) then
            return npc
        end
    end

    return nil
end

local function extractEnemyNamesFromObjectives(objectives)
    local living = getLivingFolder()
    if not living then
        return {}
    end

    local candidates = {}
    for _, npc in ipairs(living:GetChildren()) do
        if isHostileNpc(npc) then
            uniquePush(candidates, npc.Name)
        end
    end

    local matches = {}
    for _, objective in ipairs(objectives or {}) do
        for _, enemyName in ipairs(candidates) do
            if containsText(objective, enemyName) then
                uniquePush(matches, enemyName)
            end
        end
    end

    return matches
end

local function currentDungeonEnemies()
    local custom = parseCsv(Settings.dungeonEnemyInput)
    if #custom > 0 then
        return custom
    end

    local fromObjectives = extractEnemyNamesFromObjectives(Runtime.lastLairObjectives)
    if #fromObjectives > 0 then
        return fromObjectives
    end

    return nil
end

local function engageTarget(target, moveType)
    local targetRoot = getRoot(target)
    if not targetRoot then
        return false
    end

    ensureStandSummoned()
    moveTo(getOffsetCFrame(targetRoot), moveType)
    attackTarget(target)
    castAutoSkills()
    return true
end

local function updateQuestLoopKey(key)
    if Runtime.questLoop.key ~= key then
        Runtime.questLoop.key = key
        Runtime.questLoop.index = 1
        Runtime.questLoop.lastAttempt = 0
        Runtime.questLoop.snapshot = getQuestSnapshot()
    end
end

local function handleQuestAutomation(enemyNames)
    if not Settings.farmAutoQuest or not enemyNames or #enemyNames == 0 then
        return false
    end

    local entries = getQuestEntries()
    local openQuests = filterKillQuests(entries, enemyNames, false)
    if #openQuests > 0 then
        return false
    end

    local key = table.concat(enemyNames, "|")
    updateQuestLoopKey(key)

    local candidates = getQuestNpcCandidates(enemyNames)
    if #candidates == 0 then
        return false
    end

    if Runtime.questLoop.index > #candidates then
        Runtime.questLoop.index = 1
    end

    local npc = resolveNpcByName(candidates[Runtime.questLoop.index])
    local npcRoot = getRoot(npc)
    local playerRoot = getPlayerRoot()
    if not npc or not npcRoot or not playerRoot then
        return false
    end

    moveTo(npcRoot.CFrame * CFrame.new(0, 0, 6), Settings.farmMoveType)

    local currentSnapshot = getQuestSnapshot()
    if currentSnapshot ~= Runtime.questLoop.snapshot then
        Runtime.questLoop.snapshot = currentSnapshot
        Runtime.questLoop.index = 1
        return false
    end

    local distance = (playerRoot.Position - npcRoot.Position).Magnitude
    if distance <= 10 and os.clock() - Runtime.questLoop.lastAttempt >= 4 then
        Runtime.questLoop.lastAttempt = os.clock()
        Runtime.questLoop.snapshot = currentSnapshot
        triggerAnyPrompt(npc, "quest")
    elseif os.clock() - Runtime.questLoop.lastAttempt >= 7 then
        Runtime.questLoop.index = Runtime.questLoop.index + 1
        if Runtime.questLoop.index > #candidates then
            Runtime.questLoop.index = 1
        end
    end

    return true
end

local function updateDungeonLoopKey(key)
    if Runtime.dungeonLoop.key ~= key then
        Runtime.dungeonLoop.key = key
        Runtime.dungeonLoop.index = 1
        Runtime.dungeonLoop.lastAttempt = 0
    end
end

local function handleDungeonEntrance()
    if inLair() or not Settings.dungeonAutoStart then
        return false
    end

    local candidateNames
    if Settings.dungeonNpcName ~= "Auto" then
        candidateNames = {Settings.dungeonNpcName}
    else
        candidateNames = getAutoDungeonNpcCandidates()
    end

    if #candidateNames == 0 then
        return false
    end

    local loopKey = table.concat(candidateNames, "|")
    updateDungeonLoopKey(loopKey)

    if Runtime.dungeonLoop.index > #candidateNames then
        Runtime.dungeonLoop.index = 1
    end

    local npc = resolveNpcByName(candidateNames[Runtime.dungeonLoop.index])
    local npcRoot = getRoot(npc)
    local playerRoot = getPlayerRoot()
    if not npc or not npcRoot or not playerRoot then
        return false
    end

    moveTo(npcRoot.CFrame * CFrame.new(0, 0, 6), Settings.dungeonMoveType)

    local distance = (playerRoot.Position - npcRoot.Position).Magnitude
    if distance <= 10 and os.clock() - Runtime.dungeonLoop.lastAttempt >= 4 then
        Runtime.dungeonLoop.lastAttempt = os.clock()
        triggerAnyPrompt(npc, "dungeon")
    elseif os.clock() - Runtime.dungeonLoop.lastAttempt >= 8 then
        Runtime.dungeonLoop.index = Runtime.dungeonLoop.index + 1
        if Runtime.dungeonLoop.index > #candidateNames then
            Runtime.dungeonLoop.index = 1
        end
    end

    if Runtime.lastLairStart > 0 and os.clock() - Runtime.lastLairStart <= 4 then
        Runtime.dungeonLoop.successfulNpc = npc.Name
        return false
    end

    return true
end

