task.spawn(function()
    while task.wait(0.08) do
        if not Settings.dungeonEnabled then
            continue
        end

        if not inLair() then
            if handleDungeonEntrance() then
                continue
            end
        end

        if inLair() then
            local target = findNearestNpc(currentDungeonEnemies())
            if target then
                engageTarget(target, Settings.dungeonMoveType)
            else
                stopTween()
            end
        end
    end
end)

task.spawn(function()
    while task.wait(0.2) do
        if not Settings.standEnabled then
            continue
        end

        if traitGoalReached() or standGoalReached() then
            continue
        end

        ensureStock({"Rokakaka", "New Rokakaka"}, Settings.minRokaStock, Settings.autoBuyRoka, Settings.rokaMerchantTag, Settings.rokaMerchantOption)
        ensureStock({"Stand Arrow"}, Settings.minArrowStock, Settings.autoBuyArrow, Settings.arrowMerchantTag, Settings.arrowMerchantOption)

        if Settings.standUseRoka and currentStandCode() ~= "None" then
            Runtime.hadRokaDeath = false
            local usedRoka = useItemByName("Rokakaka") or useItemByName("New Rokakaka")
            if usedRoka then
                local cleared = waitForStandValue("None", 16)
                if not cleared and Runtime.hadRokaDeath then
                    task.wait(1.5)
                end
            end
        end

        if Settings.standUseArrow and currentStandCode() == "None" then
            local usedArrow = useItemByName("Stand Arrow")
            if usedArrow then
                local startedAt = os.clock()
                while os.clock() - startedAt < 12 do
                    if currentStandCode() ~= "None" then
                        break
                    end
                    task.wait(0.25)
                end
            end
        end

        task.wait(Settings.standRollDelay)
    end
end)

