local function doBuy(tag, option)
    local events = getEvents()
    local buy = events and events:FindFirstChild("BuyItem")
    if buy and buy:IsA("RemoteEvent") then
        pcall(function()
            buy:FireServer(tag, option)
        end)
    end
end

local function ensureStock(itemName, min, toggleBuy, tag, option)
    if getToolAmount(itemName) >= min then
        return true
    end

    if toggleBuy then
        doBuy(tag, option)
        task.wait(0.35)
    end

    return getToolAmount(itemName) > 0
end

local function traitGoalReached()
    if not Settings.standStopByTrait then
        return false
    end
    return nameMatches(currentTrait(), Settings.standWantedTraits)
end

local function standGoalReached()
    if not Settings.standStopByStand or #Settings.standWantedStands == 0 then
        return false
    end

    local code = currentStandCode()
    local display = getStandDisplayName(code)
    return nameMatches(code, Settings.standWantedStands) or nameMatches(display, Settings.standWantedStands)
end

local function waitForStandValue(targetValue, timeout)
    local start = os.clock()
    while os.clock() - start < timeout do
        if currentStandCode() == targetValue then
            return true
        end
        task.wait(0.2)
    end
    return false
end

