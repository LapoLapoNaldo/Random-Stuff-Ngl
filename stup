local function lower(value)
    return string.lower(tostring(value or ""))
end

local function trim(text)
    return (tostring(text or ""):gsub("^%s+", ""):gsub("%s+$", ""))
end

local function uniquePush(list, value)
    local clean = trim(value)
    if clean == "" then
        return
    end

    local target = lower(clean)
    for _, existing in ipairs(list) do
        if lower(existing) == target then
            return
        end
    end

    table.insert(list, clean)
end

local function normalizeDropdownValue(value, validOrder)
    local out = {}

    if typeof(value) == "table" then
        if #value > 0 then
            for _, entry in ipairs(value) do
                uniquePush(out, entry)
            end
        else
            local validSet = {}
            for _, entry in ipairs(validOrder or {}) do
                validSet[lower(entry)] = true
            end

            for key, enabled in pairs(value) do
                if enabled == true then
                    local keyText = tostring(key)
                    if not next(validSet) or validSet[lower(keyText)] then
                        uniquePush(out, keyText)
                    end
                end
            end

            if validOrder and #validOrder > 0 then
                table.sort(out, function(a, b)
                    local ia = math.huge
                    local ib = math.huge

                    for index, valid in ipairs(validOrder) do
                        local validLower = lower(valid)
                        if validLower == lower(a) then
                            ia = index
                        end
                        if validLower == lower(b) then
                            ib = index
                        end
                    end

                    if ia == ib then
                        return a < b
                    end
                    return ia < ib
                end)
            end
        end
    elseif value ~= nil then
        uniquePush(out, value)
    end

    return out
end

local function firstSelection(value, fallback, validOrder)
    local normalized = normalizeDropdownValue(value, validOrder)
    return normalized[1] or fallback
end

local function parseCsv(input)
    local out = {}
    if typeof(input) ~= "string" then
        return out
    end

    for token in string.gmatch(input, "([^,]+)") do
        uniquePush(out, token)
    end

    return out
end

local function containsText(haystack, needle)
    return string.find(lower(haystack), lower(needle), 1, true) ~= nil
end

local function nameMatches(name, allowedNames)
    if not allowedNames or #allowedNames == 0 then
        return true
    end

    local loweredName = lower(name)
    for _, allowed in ipairs(allowedNames) do
        local loweredAllowed = lower(allowed)
        if loweredName == loweredAllowed or string.find(loweredName, loweredAllowed, 1, true) then
            return true
        end
    end

    return false
end

local function isTaggedName(name, tags)
    local loweredName = lower(name)
    for _, tag in ipairs(tags) do
        if string.find(loweredName, tag, 1, true) then
            return true
        end
    end
    return false
end

