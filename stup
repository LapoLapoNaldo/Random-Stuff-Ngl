task.spawn(function()
	while true do
		if cfg.autofarm.enabled then
			if cfg.autofarm.autoQuest then
				local quests = Data:FindFirstChild("Quests")
				local noQuest = (not quests) or (#quests:GetChildren() == 0)
				if noQuest then
					interactWithNpc(cfg.autofarm.questNpc)
					task.wait(0.3)
				end
			end

			local target = getClosestTarget()
			local root = findRoot(target)
			if target and root and HumanoidRootPart then
				local offset = root.CFrame.LookVector * -cfg.autofarm.distance
				tweenTo(root.Position + Vector3.new(offset.X, 0, offset.Z), cfg.autofarm.speed)
				triggerAttack()
			end
		end
		task.wait(math.max(cfg.autofarm.interval, 0.05))
	end
end)

task.spawn(function()
	while true do
		if cfg.autostand.enabled then
			local standValue = Data:FindFirstChild("Stand")
			local standName = standValue and standValue.Value or "None"
			if standName == "None" then
				useEquippedItem(cfg.autostand.arrowName)
			else
				useEquippedItem(cfg.autostand.rokakaName)
			end
		end
		task.wait(math.max(cfg.autostand.delay, 0.2))
	end
end)

task.spawn(function()
	while true do
		if cfg.autobuy.enabled and BuyItemRemote then
			if hasDesiredTrait() then
				cfg.autobuy.enabled = false
			elseif cfg.autobuy.buysDone >= cfg.autobuy.maxBuys then
				cfg.autobuy.enabled = false
			else
				pcall(function()
					BuyItemRemote:FireServer(cfg.autobuy.merchantKey, cfg.autobuy.option)
				end)
				cfg.autobuy.buysDone = cfg.autobuy.buysDone + 1
			end
		end
		task.wait(math.max(cfg.autobuy.interval, 0.1))
	end
end)
