local function splitCsv(text)
	local out = {}
	for piece in string.gmatch(text or "", "([^,]+)") do
		local clean = piece:gsub("^%s+", ""):gsub("%s+$", "")
		if clean ~= "" then
			table.insert(out, clean:lower())
		end
	end
	return out
end

local function getTrait()
	local attri = Data and Data:FindFirstChild("Attri")
	return attri and attri.Value or ""
end

local function hasDesiredTrait()
	if not cfg.autobuy.stopOnTrait then
		return false
	end
	local trait = string.lower(getTrait())
	if trait == "" then
		return false
	end
	for _, name in ipairs(splitCsv(cfg.autobuy.targetTraits)) do
		if trait == name then
			return true
		end
	end
	return false
end

local function getToolByName(itemName)
	if Character then
		local inChar = Character:FindFirstChild(itemName)
		if inChar and inChar:IsA("Tool") then
			return inChar
		end
	end
	local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
	if backpack then
		local inBag = backpack:FindFirstChild(itemName)
		if inBag and inBag:IsA("Tool") then
			return inBag
		end
	end
	return nil
end

local function equipTool(tool)
	if tool and Humanoid then
		pcall(function()
			Humanoid:EquipTool(tool)
		end)
	end
end

local function useEquippedItem(toolName)
	if not UseItemRemote then
		return false
	end
	local tool = getToolByName(toolName)
	if not tool then
		return false
	end
	equipTool(tool)
	task.wait(0.1)
	pcall(function()
		UseItemRemote:FireServer()
	end)
	return true
end

local function getNpcModel(name)
	local map = workspace:FindFirstChild("Map")
	if not map then
		return nil
	end
	local npcs = map:FindFirstChild("NPCs")
	if not npcs then
		return nil
	end
	return npcs:FindFirstChild(name)
end

local function findRoot(model)
	if not model then
		return nil
	end
	return model:FindFirstChild("HumanoidRootPart")
		or model:FindFirstChild("Torso")
		or model:FindFirstChild("UpperTorso")
		or model.PrimaryPart
end

local function tweenTo(position, speed)
	if not HumanoidRootPart then
		return
	end
	local distance = (HumanoidRootPart.Position - position).Magnitude
	local duration = math.max(distance / math.max(speed, 1), 0.05)
	local tween = TweenService:Create(
		HumanoidRootPart,
		TweenInfo.new(duration, Enum.EasingStyle.Linear),
		{ CFrame = CFrame.new(position) }
	)
	tween:Play()
	tween.Completed:Wait()
end

local function touchPrompt(prompt)
	if not prompt then
		return
	end
	pcall(function()
		if fireproximityprompt then
			fireproximityprompt(prompt, 1)
		else
			prompt:InputHoldBegin()
			task.wait(prompt.HoldDuration + 0.08)
			prompt:InputHoldEnd()
		end
	end)
end

local function interactWithNpc(npcName)
	local npc = getNpcModel(npcName)
	local root = findRoot(npc)
	if not root then
		return
	end
	tweenTo(root.Position + Vector3.new(0, 0, 4), cfg.autofarm.speed)
	local prompt = npc:FindFirstChildWhichIsA("ProximityPrompt", true)
	touchPrompt(prompt)
end

local function getQuestEnemyNames()
	local out = {}
	local quests = Data and Data:FindFirstChild("Quests")
	if not quests then
		return out
	end
	for _, q in ipairs(quests:GetChildren()) do
		local enemy = q:FindFirstChild("Enemy")
		if enemy and enemy:IsA("StringValue") and enemy.Value ~= "" then
			out[enemy.Value] = true
		end
	end
	return out
end

local function isAliveMob(model)
	if not model or model == Character then
		return false
	end
	local hum = model:FindFirstChildOfClass("Humanoid")
	return hum and hum.Health > 0
end

local function getClosestTarget()
	local living = workspace:FindFirstChild("Living")
	if not living or not HumanoidRootPart then
		return nil
	end

	local questEnemies = getQuestEnemyNames()
	local chosen, bestDist
	for _, mob in ipairs(living:GetChildren()) do
		if isAliveMob(mob) then
			local root = findRoot(mob)
			if root then
				local allowed = true
				if cfg.autofarm.targetMob ~= "Auto (Quest/Nearest)" then
					allowed = mob.Name == cfg.autofarm.targetMob
				elseif cfg.autofarm.questOnly then
					allowed = questEnemies[mob.Name] == true
				end
				if allowed then
					local dist = (HumanoidRootPart.Position - root.Position).Magnitude
					if not bestDist or dist < bestDist then
						bestDist = dist
						chosen = mob
					end
				end
			end
		end
	end
	return chosen
end

local function triggerAttack()
	local equippedTool = Character and Character:FindFirstChildOfClass("Tool")
	if equippedTool then
		pcall(function()
			equippedTool:Activate()
		end)
	end
	pcall(function()
		VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
		VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
	end)
end

