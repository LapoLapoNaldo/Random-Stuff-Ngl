            if objective then
                moveToCFrame(objective.CFrame + Vector3.new(0, 3, 0), Settings.dungeonMoveType, Settings.farmTweenSpeed)
            end
        end
    end
end)

task.spawn(function()
    while task.wait(0.2) do
        if not Settings.standEnabled then
            continue
        end

        local currentTier = getCurrentStandTier()
        if currentTier >= Settings.standDesiredTier then
            continue
        end

        ensureItemStock(
            "Rokakaka",
            Settings.minRokaStock,
            Settings.autoBuyRokakaka,
            Settings.rokaMerchantTag,
            Settings.rokaMerchantOption
        )

        ensureItemStock(
            "Stand Arrow",
            Settings.minArrowStock,
            Settings.autoBuyArrow,
            Settings.arrowMerchantTag,
            Settings.arrowMerchantOption
        )

        if Settings.standAutoUseRokakaka and getCurrentStandName() ~= "None" then
            local roka = getToolByName("Rokakaka") or getToolByName("New Rokakaka")
            if roka then
                equipTool(roka)
                activateTool(roka)
                task.wait(math.max(0.6, Settings.standRollDelay))
            end
        end

        local arrow = getToolByName("Stand Arrow")
        if arrow then
            equipTool(arrow)
            activateTool(arrow)
        end

        task.wait(Settings.standRollDelay)
    end
end)

local function statusText()
    local tier = getCurrentStandTier()
    local tierName = TIER_LABELS[tier] or tostring(tier)
    local level = currentLevel()
    return string.format("Level: %d | Stand Tier: %s", level, tierName)
end

MiscTab:CreateParagraph({
    Title = "Status",
    Content = statusText(),
})

MiscTab:CreateButton({
    Name = "Mostrar Status Agora",
    Callback = function()
        notify("SUR Status", statusText())
    end,
})

