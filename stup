local function standGoalReached()
    if not Settings.standStopByStand or #Settings.standWantedStands == 0 then
        return false
    end

    local code = currentStandCode()
    local displayName = getStandDisplayName(code)
    return nameMatches(code, Settings.standWantedStands) or nameMatches(displayName, Settings.standWantedStands)
end

local function waitForStandValue(targetValue, timeout)
    local startedAt = os.clock()
    while os.clock() - startedAt < timeout do
        if currentStandCode() == targetValue then
            return true
        end
        task.wait(0.2)
    end

    return false
end

