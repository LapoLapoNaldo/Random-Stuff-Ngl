local function firstOption(v)
    if typeof(v) == "table" then
        return v[1]
    end
    return v
end

local function parseCsv(input)
    local out = {}
    if typeof(input) ~= "string" then
        return out
    end

    for token in string.gmatch(input, "([^,]+)") do
        local clean = string.gsub(token, "^%s+", "")
        clean = string.gsub(clean, "%s+$", "")
        if #clean > 0 then
            table.insert(out, clean)
        end
    end

    return out
end

local function listContainsCI(list, text)
    local t = string.lower(tostring(text or ""))
    for _, v in ipairs(list) do
        if string.lower(tostring(v)) == t then
            return true
        end
    end
    return false
end

