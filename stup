local function isConsumableTool(tool)
    return tool and tool:IsA("Tool") and ItemData[tool.Name] ~= nil
end

local function isCombatTool(tool)
    if not tool or not tool:IsA("Tool") then
        return false
    end

    if isConsumableTool(tool) then
        return false
    end

    local loweredName = lower(tool.Name)
    if loweredName == "quest" or loweredName == "dialogue" then
        return false
    end

    return true
end

local function getToolByName(name)
    for _, container in ipairs(getToolContainers()) do
        if container then
            local tool = container:FindFirstChild(name)
            if tool and tool:IsA("Tool") then
                return tool
            end
        end
    end

    return nil
end

local function getToolAmount(names)
    local total = 0
    local wanted = typeof(names) == "table" and names or {names}

    for _, container in ipairs(getToolContainers()) do
        if container then
            for _, child in ipairs(container:GetChildren()) do
                if child:IsA("Tool") and nameMatches(child.Name, wanted) then
                    total = total + (child:GetAttribute("ItemAmount") or 1)
                end
            end
        end
    end

    return total
end

local function equipTool(tool)
    local humanoid = getPlayerHumanoid()
    local character = getCharacter()
    if humanoid and tool and tool.Parent ~= character then
        humanoid:EquipTool(tool)
        task.wait(0.08)
    end
end

local function getCombatTool()
    for _, container in ipairs(getToolContainers()) do
        if container then
            for _, tool in ipairs(container:GetChildren()) do
                if isCombatTool(tool) then
                    if container ~= getCharacter() then
                        equipTool(tool)
                    end
                    return tool
                end
            end
        end
    end

    return nil
end

local function useCurrentEquippedItem()
    local remoteUse = Events:FindFirstChild("UseItem")
    if remoteUse and remoteUse:IsA("RemoteEvent") then
        pcall(function()
            remoteUse:FireServer()
        end)
    end

    local character = getCharacter()
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("Tool") and isConsumableTool(child) then
            pcall(function()
                child:Activate()
            end)
            break
        end
    end
end

local function useItemByName(itemName)
    local tool = getToolByName(itemName)
    if not tool then
        return false
    end

    equipTool(tool)

    local oldSkipPrompt = StarterGui:GetAttribute("SkipItemPrompt")
    StarterGui:SetAttribute("SkipItemPrompt", true)
    useCurrentEquippedItem()
    task.wait(0.2)

    if oldSkipPrompt == nil then
        StarterGui:SetAttribute("SkipItemPrompt", false)
    else
        StarterGui:SetAttribute("SkipItemPrompt", oldSkipPrompt)
    end

    return true
end

local function mouseAttackPulse()
    local mousePosition = UserInputService:GetMouseLocation()

    if mouse1press and mouse1release then
        pcall(mouse1press)
        task.wait(0.03)
        pcall(mouse1release)
    elseif mouse1click then
        pcall(mouse1click)
    end

    if VirtualInputManager then
        pcall(function()
            VirtualInputManager:SendMouseButtonEvent(mousePosition.X, mousePosition.Y, 0, true, game, 0)
            task.wait(0.03)
            VirtualInputManager:SendMouseButtonEvent(mousePosition.X, mousePosition.Y, 0, false, game, 0)
        end)
    end

    pcall(function()
        VirtualUser:CaptureController()
        VirtualUser:Button1Down(Vector2.new(mousePosition.X, mousePosition.Y), workspace.CurrentCamera.CFrame)
        task.wait(0.03)
        VirtualUser:Button1Up(Vector2.new(mousePosition.X, mousePosition.Y), workspace.CurrentCamera.CFrame)
    end)
end

local function attackTarget(target)
    local targetRoot = getRoot(target)
    if not targetRoot then
        return
    end

    if Settings.farmLookAtNpc then
        lookAt(targetRoot.Position)
    end

    local combatTool = getCombatTool()
    if combatTool then
        pcall(function()
            combatTool:Activate()
        end)
    end

    if os.clock() - Runtime.lastMouseAttack >= Settings.farmHitInterval * 0.5 then
        Runtime.lastMouseAttack = os.clock()
        mouseAttackPulse()
    end
end

local function pressKey(letter)
    local keyCode = Enum.KeyCode[letter]
    if not keyCode then
        return
    end

    if keypress and keyrelease then
        pcall(function()
            keypress(keyCode.Value)
            task.wait(0.05)
            keyrelease(keyCode.Value)
        end)
    end

    if VirtualInputManager then
        pcall(function()
            VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
        end)
    end
end

local function castAutoSkills()
    if not Settings.autoSkillsEnabled then
        return
    end

    local now = os.clock()
    for _, letter in ipairs(Settings.autoSkillKeys) do
        local lastCast = Runtime.lastSkillCastByKey[letter] or 0
        if now - lastCast >= Settings.autoSkillInterval then
            pressKey(letter)
            Runtime.lastSkillCastByKey[letter] = now
            task.wait(0.04)
        end
    end
end

local function ensureStandSummoned()
