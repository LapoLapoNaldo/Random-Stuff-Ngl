task.spawn(function()
    while task.wait(Settings.farmHitInterval) do
        if not Settings.farmEnabled then
            continue
        end

        local root = getPlayerRoot()
        if not root then
            continue
        end

        local enemies = getFarmEnemyList()
        local target = findNearestNpc(enemies)
        if target then
            local targetRoot = getRoot(target)
            if targetRoot then
                local attackCf = getOffsetCFrame(
                    targetRoot,
                    Settings.farmAttackPosition,
                    Settings.farmAttackDistance,
                    Settings.farmAttackHeight
                )
                moveToCFrame(attackCf, Settings.farmMoveType, Settings.farmTweenSpeed)
                hitNpc(target)
            end
        end
    end
end)

task.spawn(function()
