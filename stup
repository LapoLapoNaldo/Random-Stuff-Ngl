    local character = getCharacter()
    if character:FindFirstChild("Stand") then
        return
    end

    if os.clock() - Runtime.lastStandSummon < 1.5 then
        return
    end

    Runtime.lastStandSummon = os.clock()
    pressKey("Q")
end

