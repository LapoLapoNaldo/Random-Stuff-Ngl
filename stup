    return ch and getRoot(ch)
end

local function isAliveHumanoid(h)
    return h and h.Health > 0
end

local function currentLevel()
    local data = LocalPlayer:FindFirstChild("Data")
    local lv = data and data:FindFirstChild("Level")
    return (lv and lv.Value) or 1
end

local function getCurrentStandTier()
    local ch = getCharacter()
    local stats = ch and ch:FindFirstChild("Stats")
    local tier = stats and stats:FindFirstChild("StandTier")
    local value = tier and tier.Value

    if typeof(value) == "number" then
        return value
    end
    if typeof(value) == "string" then
        local parsed = tonumber(value)
        if parsed then
            return parsed
        end
    end

    return 0
end

local function getCurrentStandName()
    local data = LocalPlayer:FindFirstChild("Data")
    local stand = data and data:FindFirstChild("Stand")
    return stand and stand.Value or "None"
end

local function getLivingFolder()
    return workspace:FindFirstChild("Living")
end

local function isHostileNpc(model)
    if not model or not model:IsA("Model") then
        return false
    end

    local char = LocalPlayer.Character
    if char and model == char then
        return false
    end

    local hum = getHumanoid(model)
    local root = getRoot(model)
    if not hum or not root or hum.Health <= 0 then
        return false
    end

    local lowerName = string.lower(model.Name)
    for word in pairs(IGNORE_NAME_MATCH) do
        if string.find(lowerName, word, 1, true) then
            return false
        end
    end

    return true
end

local function normalizeName(name)
    return string.lower(tostring(name))
end

local function nameMatches(name, list)
    local target = normalizeName(name)
    for _, v in ipairs(list) do
        local nv = normalizeName(v)
        if target == nv or string.find(target, nv, 1, true) then
            return true
        end
    end
    return false
end

local function getActiveQuestEnemies()
    local data = LocalPlayer:FindFirstChild("Data")
    local quests = data and data:FindFirstChild("Quests")
    local enemies = {}

    if not quests then
        return enemies
    end

    for _, quest in ipairs(quests:GetChildren()) do
        local typ = quest:FindFirstChild("Type")
        local enemy = quest:FindFirstChild("Enemy")
        local completed = quest:FindFirstChild("Completed")

        if typ and enemy and typ.Value == "Kill" and (not completed or completed.Value == false) then
            table.insert(enemies, enemy.Value)
        end
    end

    return enemies
end

local function getRecommendedEnemies()
    local lv = currentLevel()
    for _, route in ipairs(QUEST_ROUTE) do
        if lv >= route.min and lv <= route.max then
            return route.enemies
        end
    end
    return {"Jungle Bandit"}
end

local function getFarmEnemyList()
    if Settings.farmUseActiveQuest then
        local active = getActiveQuestEnemies()
        if #active > 0 then
            return active
        end
    end

    return getRecommendedEnemies()
end

local function findNearestNpc(allowedNames)
    local root = getPlayerRoot()
    local living = getLivingFolder()

    if not root or not living then
        return nil
    end

    local nearestModel
    local nearestDistance = math.huge

    for _, npc in ipairs(living:GetChildren()) do
        if isHostileNpc(npc) then
            if (not allowedNames) or nameMatches(npc.Name, allowedNames) then
                local npcRoot = getRoot(npc)
                if npcRoot then
                    local dist = (root.Position - npcRoot.Position).Magnitude
                    if dist < nearestDistance then
                        nearestDistance = dist
                        nearestModel = npc
                    end
                end
            end
        end
    end

    return nearestModel, nearestDistance
end

local function findDungeonObjectivePart()
    local bestPart
    local bestDistance = math.huge
    local root = getPlayerRoot()
    if not root then
        return nil
    end

    for _, inst in ipairs(workspace:GetDescendants()) do
        if inst:IsA("BasePart") then
            local n = string.lower(inst.Name)
            if string.find(n, "objective", 1, true)
                or string.find(n, "goal", 1, true)
                or string.find(n, "dungeon", 1, true)
                or string.find(n, "boss", 1, true)
                or string.find(n, "portal", 1, true)
            then
                local d = (root.Position - inst.Position).Magnitude
                if d < bestDistance then
                    bestDistance = d
                    bestPart = inst
                end
            end
        end
    end

    return bestPart
end

local function getOffsetCFrame(targetRoot, attackPosition, attackDistance, attackHeight)
    local localOffset

    if attackPosition == "Behind" then
        localOffset = CFrame.new(0, attackHeight, attackDistance)
    elseif attackPosition == "Front" then
        localOffset = CFrame.new(0, attackHeight, -attackDistance)
    else
        localOffset = CFrame.new(0, attackHeight + attackDistance, 0)
    end

    return targetRoot.CFrame * localOffset
end

local function faceTarget(targetPosition)
    local root = getPlayerRoot()
    if not root then
        return
    end

    local lookPos = Vector3.new(targetPosition.X, root.Position.Y, targetPosition.Z)
    root.CFrame = CFrame.lookAt(root.Position, lookPos)
end

local function stopActiveTween()
    if activeTween then
        pcall(function()
            activeTween:Cancel()
        end)
        activeTween = nil
    end
end

local function moveToCFrame(targetCFrame, moveType, tweenSpeed)
    local root = getPlayerRoot()
    if not root then
        return
    end

    if moveType == "TP" then
        stopActiveTween()
        root.CFrame = targetCFrame
        return
    end

    local distance = (root.Position - targetCFrame.Position).Magnitude
    local duration = math.clamp(distance / math.max(tweenSpeed, 1), 0.05, 2)

    stopActiveTween()
    activeTween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
        CFrame = targetCFrame,
    })
    activeTween:Play()
end

local function getToolByName(name)
    local ch = getCharacter()
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")

    if ch then
        local inChar = ch:FindFirstChild(name)
        if inChar and inChar:IsA("Tool") then
            return inChar
        end
    end

    if backpack then
        local inBp = backpack:FindFirstChild(name)
        if inBp and inBp:IsA("Tool") then
            return inBp
        end
    end

    return nil
end

local function getToolAmount(name)
    local total = 0
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    local ch = getCharacter()

    local function countIn(container)
        if not container then
            return
        end
        for _, child in ipairs(container:GetChildren()) do
            if child:IsA("Tool") and child.Name == name then
                total += (child:GetAttribute("ItemAmount") or 1)
            end
        end
    end

    countIn(backpack)
    countIn(ch)

    return total
end

local function equipTool(tool)
    local hum = getPlayerHumanoid()
    if hum and tool and tool.Parent ~= getCharacter() then
        hum:EquipTool(tool)
    end
end

local function activateTool(tool)
    if not tool then
        return false
    end

    local ok = pcall(function()
        tool:Activate()
    end)

    if not ok and mouse1click then
        pcall(function()
            mouse1click()
        end)
    end

    return ok
end

local function equipAnyCombatTool()
    local ch = getCharacter()
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")

    local function validTool(t)
        if not t:IsA("Tool") then
            return false
        end

        local n = string.lower(t.Name)
        if string.find(n, "arrow", 1, true) then return false end
        if string.find(n, "rokakaka", 1, true) then return false end
        if string.find(n, "mask", 1, true) then return false end
        if string.find(n, "diary", 1, true) then return false end

        return true
    end

    if ch then
        for _, t in ipairs(ch:GetChildren()) do
            if validTool(t) then
                return t
            end
        end
    end

    if backpack then
        for _, t in ipairs(backpack:GetChildren()) do
            if validTool(t) then
                equipTool(t)
                return t
            end
        end
    end

    return nil
end

local function hitNpc(npc)
    local npcRoot = getRoot(npc)
    if not npcRoot then
        return
    end

    if Settings.farmLookAtNpc or Settings.dungeonLookAtNpc then
        faceTarget(npcRoot.Position)
    end

    local tool = equipAnyCombatTool()
    if tool then
        activateTool(tool)
    elseif mouse1click then
        pcall(function()
            mouse1click()
        end)
    end
end

local function getEventsFolder()
    return ReplicatedStorage:FindFirstChild("Events")
end

local function tryBuyItem(tag, option)
    local events = getEventsFolder()
    local buyItem = events and events:FindFirstChild("BuyItem")

    if buyItem and buyItem:IsA("RemoteEvent") then
        pcall(function()
            buyItem:FireServer(tag, option)
        end)
        return true
    end

    return false
end

local function ensureItemStock(itemName, minAmount, shouldBuy, merchantTag, merchantOption)
    local amount = getToolAmount(itemName)
    if amount >= minAmount then
        return true
    end

    if shouldBuy then
        tryBuyItem(merchantTag, merchantOption)
        task.wait(0.35)
    end

    return getToolAmount(itemName) >= 1
end

