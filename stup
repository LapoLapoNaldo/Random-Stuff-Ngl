local function isHostileNpc(model)
    if not model or not model:IsA("Model") then
        return false
    end

    if model == LocalPlayer.Character then
        return false
    end

    if Players:GetPlayerFromCharacter(model) then
        return false
    end

    local hum = getHumanoid(model)
    local root = getRoot(model)
    if not hum or not root or hum.Health <= 0 then
        return false
    end

    local lower = string.lower(model.Name)
    if string.find(lower, "dummy", 1, true) then
        return false
    end

    return true
end

local function getEnemyLevel(model)
    if not model then
        return nil
    end

    local lv = model:FindFirstChild("Level")
    if lv and (lv:IsA("IntValue") or lv:IsA("NumberValue")) then
        return lv.Value
    end

    local stats = model:FindFirstChild("Stats")
    local lv2 = stats and stats:FindFirstChild("Level")
    if lv2 and (lv2:IsA("IntValue") or lv2:IsA("NumberValue")) then
        return lv2.Value
    end

    return nil
end

local function getRecommendedEnemiesByNpcLevel()
    local living = getLivingFolder()
    if not living then
        return {}
    end

    local byName = {}
    for _, npc in ipairs(living:GetChildren()) do
        if isHostileNpc(npc) then
            local lv = getEnemyLevel(npc)
            if lv then
                byName[npc.Name] = lv
            end
        end
    end

    local me = currentLevel()
    local bestName
    local bestScore = math.huge

    for name, lv in pairs(byName) do
        local diff = math.abs(me - lv)
        local penalty = lv > me and 8 or 0
        local score = diff + penalty
        if score < bestScore then
            bestScore = score
            bestName = name
        end
    end

    if bestName then
        return {bestName}
    end

    for _, route in ipairs(DEFAULT_ROUTE) do
        if me >= route.min and me <= route.max then
            return route.enemies
        end
    end

    return {"Jungle Bandit"}
end

local function getActiveQuestEnemies()
    local d = getData()
    local q = d and d:FindFirstChild("Quests")
    local out = {}

    if not q then
        return out
    end

    for _, quest in ipairs(q:GetChildren()) do
        local typ = quest:FindFirstChild("Type")
        local enemy = quest:FindFirstChild("Enemy")
        local completed = quest:FindFirstChild("Completed")
        if typ and enemy and typ.Value == "Kill" and ((not completed) or completed.Value == false) then
            table.insert(out, enemy.Value)
        end
    end

    return out
end

local function currentFarmEnemies()
    if Settings.farmTargetMode == "Nearest" then
        return nil
    end

    if Settings.farmTargetMode == "Custom" then
        return parseCsv(Settings.farmCustomEnemyInput)
    end

    if Settings.farmTargetMode == "Recommended" then
        return getRecommendedEnemiesByNpcLevel()
    end

    local active = getActiveQuestEnemies()
    if #active > 0 then
        return active
    end

    return getRecommendedEnemiesByNpcLevel()
end

local function nameMatches(name, list)
    if not list or #list == 0 then
        return true
    end

    local n = string.lower(name)
    for _, item in ipairs(list) do
        local key = string.lower(item)
        if n == key or string.find(n, key, 1, true) then
            return true
        end
    end
    return false
end

local function findNearestNpc(allowedNames)
    local root = getPlayerRoot()
    local living = getLivingFolder()
    if not root or not living then
        return nil
    end

    local best
    local bestDist = math.huge

    for _, npc in ipairs(living:GetChildren()) do
        if isHostileNpc(npc) and nameMatches(npc.Name, allowedNames) then
            local nroot = getRoot(npc)
            if nroot then
                local d = (root.Position - nroot.Position).Magnitude
                if d < bestDist then
                    bestDist = d
                    best = npc
                end
            end
        end
    end

    return best
end

local function getOffsetCFrame(targetRoot)
    local dist = Settings.farmAttackDistance
    local h = Settings.farmAttackHeight
    local mode = Settings.farmAttackPosition
    local offset

    if mode == "Behind" then
        offset = CFrame.new(0, h, dist)
    elseif mode == "Front" then
        offset = CFrame.new(0, h, -dist)
    elseif mode == "Above" then
        offset = CFrame.new(0, h + dist, 0)
    elseif mode == "Under" then
        offset = CFrame.new(0, h - dist, 0)
    elseif mode == "Left" then
        offset = CFrame.new(-dist, h, 0)
    else
        offset = CFrame.new(dist, h, 0)
    end

    return targetRoot.CFrame * offset
end

local function stopTween()
    if activeTween then
        pcall(function()
            activeTween:Cancel()
        end)
        activeTween = nil
    end
end

local function moveTo(targetCf, moveType)
    local root = getPlayerRoot()
    local ch = getCharacter()
    if not root or not ch then
        return
    end

    if moveType == "TP" then
        stopTween()
        pcall(function()
            ch:PivotTo(targetCf)
        end)
        root.CFrame = targetCf
        return
    end

    local dist = (root.Position - targetCf.Position).Magnitude
    local t = math.clamp(dist / math.max(Settings.farmTweenSpeed, 1), 0.05, 1.6)

    stopTween()
    activeTween = TweenService:Create(root, TweenInfo.new(t, Enum.EasingStyle.Linear), {CFrame = targetCf})
    activeTween:Play()
end

local function lookAt(pos)
    local root = getPlayerRoot()
    if not root then
        return
    end
    local look = Vector3.new(pos.X, root.Position.Y, pos.Z)
    root.CFrame = CFrame.lookAt(root.Position, look)
end

local function getToolByName(name)
    local ch = getCharacter()
    local bp = LocalPlayer:FindFirstChildOfClass("Backpack")

    local t1 = ch and ch:FindFirstChild(name)
    if t1 and t1:IsA("Tool") then
        return t1
    end

    local t2 = bp and bp:FindFirstChild(name)
    if t2 and t2:IsA("Tool") then
        return t2
    end

    return nil
end

local function getToolAmount(name)
    local total = 0
    local ch = getCharacter()
    local bp = LocalPlayer:FindFirstChildOfClass("Backpack")

    local function scan(container)
        if not container then
            return
        end
        for _, child in ipairs(container:GetChildren()) do
            if child:IsA("Tool") and child.Name == name then
                total += (child:GetAttribute("ItemAmount") or 1)
            end
        end
    end

    scan(ch)
    scan(bp)
    return total
end

local function equipTool(tool)
    local hum = getPlayerHumanoid()
    if hum and tool and tool.Parent ~= getCharacter() then
        hum:EquipTool(tool)
        task.wait(0.08)
    end
end

local function useCurrentEquippedItem()
    local events = getEvents()
    local remoteUse = events and events:FindFirstChild("UseItem")

    if remoteUse and remoteUse:IsA("RemoteEvent") then
        pcall(function()
            remoteUse:FireServer()
        end)
    end

    local ch = getCharacter()
    for _, child in ipairs(ch:GetChildren()) do
        if child:IsA("Tool") then
            local useRemote = child:FindFirstChild("Use")
            if useRemote and useRemote:IsA("RemoteEvent") then
                pcall(function()
                    useRemote:FireServer()
                end)
            end
            pcall(function()
                child:Activate()
            end)
            break
        end
    end
end

local function useItemByName(itemName)
    local tool = getToolByName(itemName)
    if not tool then
        return false
    end

    equipTool(tool)

    local oldSkip = StarterGui:GetAttribute("SkipItemPrompt")
    StarterGui:SetAttribute("SkipItemPrompt", true)
    useCurrentEquippedItem()
    task.wait(0.2)

    if oldSkip == nil then
        StarterGui:SetAttribute("SkipItemPrompt", false)
    else
        StarterGui:SetAttribute("SkipItemPrompt", oldSkip)
    end

    return true
end

local function getCombatTool()
    local ch = getCharacter()
    local bp = LocalPlayer:FindFirstChildOfClass("Backpack")

    local blocked = {
        ["stand arrow"] = true,
        ["charged arrow"] = true,
        ["anniversary arrow"] = true,
        ["requiem arrow"] = true,
        ["rokakaka"] = true,
        ["new rokakaka"] = true,
    }

    local function valid(tool)
        if not tool:IsA("Tool") then
            return false
        end
        local n = string.lower(tool.Name)
        if blocked[n] then
            return false
        end
        return true
    end

    for _, t in ipairs(ch:GetChildren()) do
        if valid(t) then
            return t
        end
    end

    for _, t in ipairs(bp and bp:GetChildren() or {}) do
        if valid(t) then
            equipTool(t)
            return t
        end
    end

    return nil
end

local function mouseAttackPulse()
    if mouse1press and mouse1release then
        pcall(mouse1press)
        task.wait(0.03)
        pcall(mouse1release)
        return
    end

    if mouse1click then
        pcall(mouse1click)
        return
    end

    if VirtualInputManager then
        pcall(function()
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            task.wait(0.03)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end)
    end
end

local function attackTarget(target)
    local targetRoot = getRoot(target)
    if not targetRoot then
        return
    end

    if Settings.farmLookAtNpc then
        lookAt(targetRoot.Position)
    end

    local tool = getCombatTool()
    if tool then
        pcall(function()
            tool:Activate()
        end)
    end

    mouseAttackPulse()
end

local function pressKey(letter)
    local key = Enum.KeyCode[letter]
    if not key then
        return
    end

    if keypress and keyrelease then
        pcall(function()
            keypress(key.Value)
            task.wait(0.05)
            keyrelease(key.Value)
        end)
        return
    end

    if VirtualInputManager then
        pcall(function()
            VirtualInputManager:SendKeyEvent(true, key, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(false, key, false, game)
        end)
    end
end

local function castAutoSkills()
    if not Settings.autoSkillsEnabled then
        return
    end

    if os.clock() - lastSkillTick < Settings.autoSkillInterval then
        return
    end

    for _, letter in ipairs(Settings.autoSkillKeys) do
        pressKey(letter)
        task.wait(0.04)
    end

    lastSkillTick = os.clock()
end

