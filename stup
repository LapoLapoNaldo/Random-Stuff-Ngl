    end

    if Settings.farmTargetMode == "Recommended" then
        return getRouteForLevel(currentLevel()).enemies
    end

    local active = getActiveQuestEnemies()
    if #active > 0 then
        return active
    end

    return getRouteForLevel(currentLevel()).enemies
end

local function findNearestNpc(allowedNames)
    local root = getPlayerRoot()
    local living = getLivingFolder()
    if not root or not living then
        return nil
    end

    local bestTarget
    local bestDistance = math.huge

    for _, npc in ipairs(living:GetChildren()) do
        if isHostileNpc(npc) and nameMatches(npc.Name, allowedNames) then
            local npcRoot = getRoot(npc)
            if npcRoot then
                local distance = (root.Position - npcRoot.Position).Magnitude
                if distance < bestDistance then
                    bestDistance = distance
                    bestTarget = npc
                end
            end
        end
    end

    return bestTarget
end

local function getOffsetCFrame(targetRoot)
    local distance = Settings.farmAttackDistance
    local height = Settings.farmAttackHeight
    local positionMode = Settings.farmAttackPosition
    local offset

    if positionMode == "Behind" then
        offset = CFrame.new(0, height, distance)
    elseif positionMode == "Front" then
        offset = CFrame.new(0, height, -distance)
    elseif positionMode == "Above" then
        offset = CFrame.new(0, height + distance, 0)
    elseif positionMode == "Under" then
        offset = CFrame.new(0, height - distance, 0)
    elseif positionMode == "Left" then
        offset = CFrame.new(-distance, height, 0)
    else
        offset = CFrame.new(distance, height, 0)
    end

    return targetRoot.CFrame * offset
end

local function stopTween()
    if Runtime.activeTween then
        pcall(function()
            Runtime.activeTween:Cancel()
        end)
    end

    Runtime.activeTween = nil
    Runtime.activeTweenGoal = nil
end

local function moveTo(targetCFrame, moveType)
    local root = getPlayerRoot()
    local character = getCharacter()
    if not root or not character then
        return
    end

    if moveType == "TP" then
        stopTween()
        Runtime.activeTweenGoal = targetCFrame
        pcall(function()
            character:PivotTo(targetCFrame)
        end)
        root.CFrame = targetCFrame
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        return
    end

    if Runtime.activeTweenGoal and (Runtime.activeTweenGoal.Position - targetCFrame.Position).Magnitude <= 2 then
        return
    end

    local distance = (root.Position - targetCFrame.Position).Magnitude
    local tweenTime = math.clamp(distance / math.max(Settings.farmTweenSpeed, 1), 0.06, 1.2)

    stopTween()
    Runtime.activeTweenGoal = targetCFrame
    Runtime.activeTween = TweenService:Create(root, TweenInfo.new(tweenTime, Enum.EasingStyle.Linear), {
        CFrame = targetCFrame,
    })
    Runtime.activeTween:Play()
end

local function lookAt(position)
    local root = getPlayerRoot()
    if not root then
        return
    end

    local flatTarget = Vector3.new(position.X, root.Position.Y, position.Z)
    root.CFrame = CFrame.lookAt(root.Position, flatTarget)
end

