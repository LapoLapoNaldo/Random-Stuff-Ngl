task.spawn(function()
    while task.wait(0.2) do
        local hum = getPlayerHumanoid()
        if hum then
            if Settings.walkSpeedEnabled then
                hum.WalkSpeed = Settings.walkSpeed
            end
            if Settings.jumpPowerEnabled then
                hum.JumpPower = Settings.jumpPower
            end
        end
    end
end)

task.spawn(function()
    while task.wait(0.05) do
        if not Settings.farmEnabled then
            continue
        end

        local target = findNearestNpc(currentFarmEnemies())
        if target then
            local tr = getRoot(target)
            if tr then
                ensureStandSummoned()
                local cf = getOffsetCFrame(tr)
                moveTo(cf, Settings.farmMoveType)
                attackTarget(target)
                castAutoSkills()
            end
        end

        task.wait(Settings.farmHitInterval)
    end
end)

task.spawn(function()
    while task.wait(0.2) do
        if not Settings.dungeonEnabled then
            continue
        end

        if not inLair() and Settings.dungeonAutoStart then
            local npc = findDungeonNpcModel()
            local npcRoot = getRoot(npc)
            if npcRoot then
                moveTo(npcRoot.CFrame + Vector3.new(0, 0, 3), Settings.dungeonMoveType)
                local pr = getPlayerRoot()
                if pr and (pr.Position - npcRoot.Position).Magnitude <= 12 then
                    triggerAnyPrompt(npc)
                end
            end
        end

        local enemies = parseCsv(Settings.dungeonEnemyInput)
        local target = findNearestNpc(#enemies > 0 and enemies or nil)
        if target then
            local tr = getRoot(target)
            if tr then
                ensureStandSummoned()
                local cf = getOffsetCFrame(tr)
                moveTo(cf, Settings.dungeonMoveType)
                attackTarget(target)
                castAutoSkills()
            end
        end
    end
end)

task.spawn(function()
    while task.wait(0.2) do
        if not Settings.standEnabled then
            continue
        end

        if traitGoalReached() or standGoalReached() then
            continue
        end

        ensureStock("Rokakaka", Settings.minRokaStock, Settings.autoBuyRoka, Settings.rokaMerchantTag, Settings.rokaMerchantOption)
        ensureStock("Stand Arrow", Settings.minArrowStock, Settings.autoBuyArrow, Settings.arrowMerchantTag, Settings.arrowMerchantOption)

        if Settings.standUseRoka and currentStandCode() ~= "None" then
            hadRokaDeath = false
            local usedRoka = useItemByName("Rokakaka") or useItemByName("New Rokakaka")
            if usedRoka then
                local okClear = waitForStandValue("None", 16)
                if not okClear and hadRokaDeath then
                    task.wait(1.5)
                end
            end
        end

        if Settings.standUseArrow and currentStandCode() == "None" then
            local usedArrow = useItemByName("Stand Arrow")
            if usedArrow then
                local start = os.clock()
                while os.clock() - start < 12 do
                    if currentStandCode() ~= "None" then
                        break
                    end
                    task.wait(0.25)
                end
            end
        end

        task.wait(Settings.standRollDelay)
    end
end)

