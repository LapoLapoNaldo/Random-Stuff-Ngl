local function findDungeonNpcModel()
    local map = workspace:FindFirstChild("Map")
    local npcs = map and map:FindFirstChild("NPCs")
    if not npcs then
        return nil
    end

    if Settings.dungeonNpcName ~= "Auto" then
        return npcs:FindFirstChild(Settings.dungeonNpcName)
    end

    local root = getPlayerRoot()
    if not root then
        return nil
    end

    local best, bestDist = nil, math.huge
    for _, npc in ipairs(npcs:GetChildren()) do
        local nr = getRoot(npc)
        if nr then
            local d = (root.Position - nr.Position).Magnitude
            if d < bestDist then
                bestDist = d
                best = npc
            end
        end
    end

    return best
end

local function triggerAnyPrompt(model)
    if not model then
        return false
    end

    for _, d in ipairs(model:GetDescendants()) do
        if d:IsA("ProximityPrompt") then
            if fireproximityprompt then
                pcall(function()
                    fireproximityprompt(d)
                end)
                return true
            end

            pcall(function()
                d:InputHoldBegin()
                task.wait(0.15)
                d:InputHoldEnd()
            end)
            return true
        end
    end

    return false
end

