        if not Settings.dungeonEnabled then
            continue
        end

        local target = findNearestNpc(nil)
        if target then
            local targetRoot = getRoot(target)
            if targetRoot then
                local attackCf = getOffsetCFrame(
                    targetRoot,
                    Settings.farmAttackPosition,
                    Settings.farmAttackDistance,
                    Settings.farmAttackHeight
                )
                moveToCFrame(attackCf, Settings.dungeonMoveType, Settings.farmTweenSpeed)
