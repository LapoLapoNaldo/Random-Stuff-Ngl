local function getAllTraitOptions()
    local options = {}
    local add = function(value)
        if value and #tostring(value) > 0 and not listContainsCI(options, value) then
            table.insert(options, tostring(value))
        end
    end

    for _, t in ipairs(DEFAULT_TRAITS) do
        add(t)
    end

    local d = getData()
    if d then
        add(d:FindFirstChild("Attri") and d.Attri.Value)
        for i = 1, 5 do
            local slot = d:FindFirstChild("Slot" .. i .. "Attri")
            if slot then
                add(slot.Value)
            end
        end
    end

    table.sort(options)
    return options
end

local function getAllStandOptions()
