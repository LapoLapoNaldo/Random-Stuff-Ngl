local function ensureStock(itemNames, minimum, autoBuyEnabled, tag, option)
    if getToolAmount(itemNames) >= minimum then
        return true
    end

    if autoBuyEnabled then
        doBuy(tag, option)
        task.wait(0.35)
    end

    return getToolAmount(itemNames) > 0
end

