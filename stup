local function isHostileNpc(model)
    if not model or not model:IsA("Model") then
        return false
    end

    if model == LocalPlayer.Character then
        return false
    end

    if Players:GetPlayerFromCharacter(model) then
        return false
    end

    local root = getRoot(model)
    local humanoid = getHumanoid(model)
    if not root or not humanoid or humanoid.Health <= 0 then
        return false
    end

    local loweredName = lower(model.Name)
    if string.find(loweredName, "dummy", 1, true) then
        return false
    end

    return true
end

local function getEnemyLevel(model)
    if not model then
        return nil
    end

    local level = model:FindFirstChild("Level")
    if level and (level:IsA("IntValue") or level:IsA("NumberValue")) then
        return level.Value
    end

    local stats = model:FindFirstChild("Stats")
    local statsLevel = stats and stats:FindFirstChild("Level")
    if statsLevel and (statsLevel:IsA("IntValue") or statsLevel:IsA("NumberValue")) then
        return statsLevel.Value
    end

    return nil
end

local function getQuestEntries()
    local out = {}
    local data = getData()
    local quests = data and data:FindFirstChild("Quests")
    if not quests then
        return out
    end

    for _, quest in ipairs(quests:GetChildren()) do
        local questType = quest:FindFirstChild("Type")
        local enemy = quest:FindFirstChild("Enemy")
        local completed = quest:FindFirstChild("Completed")
        local kills = quest:FindFirstChild("Kills")
        local maxKills = quest:FindFirstChild("MaxKills")
        local title = quest:FindFirstChild("Title")
        local description = quest:FindFirstChild("Des")

        table.insert(out, {
            instance = quest,
            name = quest.Name,
            type = questType and questType.Value or "",
            enemy = enemy and enemy.Value or "",
            completed = completed and completed.Value or false,
            kills = kills and kills.Value or 0,
            maxKills = maxKills and maxKills.Value or 0,
            title = title and title.Value or quest.Name,
            description = description and description.Value or "",
        })
    end

    return out
end

local function getQuestSnapshot()
    local chunks = {}
    for _, quest in ipairs(getQuestEntries()) do
        table.insert(chunks, string.format(
            "%s|%s|%s|%s|%s",
            quest.name,
            quest.enemy,
            tostring(quest.completed),
            tostring(quest.kills),
            tostring(quest.maxKills)
        ))
    end
    table.sort(chunks)
    return table.concat(chunks, "||")
end

local function filterKillQuests(entries, enemyNames, completedState)
    local out = {}
    for _, quest in ipairs(entries) do
        if quest.type == "Kill" and nameMatches(quest.enemy, enemyNames) then
            if completedState == nil or quest.completed == completedState then
                table.insert(out, quest)
            end
        end
    end
    return out
end

